# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Backend API Configuration
# Use localhost for development on same machine
# Use your machine IP (192.168.x.x) for device testing
# Use production URL for production
EXPO_PUBLIC_API_URL=http://localhost:3000

# Alternative IPs for testing on devices:
# Android emulator from host: http://10.0.2.2:3000
# iOS simulator: http://localhost:3000
# Physical device: http://<your-machine-ip>:3000
